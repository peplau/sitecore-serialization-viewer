{
  "name": "sitecore-serialization-viewer",
  "displayName": "Sitecore Serialization Viewer",
  "description": "Helps Sitecore Developers visualize how SCS Serialization is configured in a project",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.110.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onView:sitecoreContentTree"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "configuration": {
      "type": "object",
      "title": "Sitecore Serialization Viewer",
      "properties": {
        "sitecoreSerializationViewer.authoringGraphqlUrl": {
          "type": "string",
          "default": "",
          "description": "Optional full Authoring GraphQL URL for Sitecore (e.g., https://<hostname>/sitecore/api/authoring/graphql/v1/)"
        },
        "sitecoreSerializationViewer.defaultSiteName": {
          "type": "string",
          "default": "my-website",
          "description": "Default site name for GraphQL preview (fallback/environment variable NEXT_PUBLIC_DEFAULT_SITE_NAME)"
        },
        "sitecoreSerializationViewer.defaultLanguage": {
          "type": "string",
          "default": "en",
          "description": "Default Sitecore language for GraphQL requests (fallback/environment variable LANGUAGE)"
        },
        "sitecoreSerializationViewer.defaultDatabase": {
          "type": "string",
          "default": "master",
          "description": "Default Sitecore database for GraphQL requests (fallback/environment variable SITECORE_DATABASE)"
        }
      }
    },
    "commands": [
      {
        "command": "sitecore-serialization-viewer.helloWorld",
        "title": "Hello World"
      },
      {
        "command": "sitecore-serialization-viewer.refreshTree",
        "title": "Refresh Content Tree",
        "icon": "$(refresh)"
      },
      {
        "command": "sitecore-serialization-viewer.copyPath",
        "title": "Copy Sitecore Path"
      },
      {
        "command": "sitecore-serialization-viewer.showDetails",
        "title": "Show Details"
      }
    ],
    "views": {
      "explorer": [
        {
          "id": "sitecoreContentTree",
          "name": "Sitecore Serialization Viewer",
          "icon": "$(folder)",
          "contextualTitle": "Sitecore Serialization Viewer"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "sitecore-serialization-viewer.refreshTree",
          "when": "view == sitecoreContentTree",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "sitecore-serialization-viewer.copyPath",
          "when": "view == sitecoreContentTree",
          "group": "7_modification"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && npm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && npm run lint && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.110.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "typescript-eslint": "^8.56.1",
    "eslint": "^9.39.3",
    "esbuild": "^0.27.3",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.9.3",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2"
  }
}
